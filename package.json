{
  "name": "kasoku-monorepo",
  "private": true,
  "packageManager": "npm@10.5.2",
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@kasoku/web",
    "build": "turbo run build --filter=@kasoku/web",
    "lint": "turbo run lint",
    "test": "jest",
    "dev:all": "turbo run dev",
    "build:all": "turbo run build",
    "dev:web": "turbo run dev --filter=@kasoku/web",
    "build:web": "turbo run build --filter=@kasoku/web",
    "lint:web": "turbo run lint --filter=@kasoku/web",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "eslint-plugin-rulesdir": "^0.2.2",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.55.1",
    "prettier": "^3.0.0",
    "ts-jest": "^29.3.4",
    "turbo": "^2.5.4"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.33.7",
    "@radix-ui/react-icons": "^1.3.2",
    "@tiptap/extension-color": "^3.6.1",
    "@tiptap/extension-highlight": "^3.6.1",
    "@tiptap/extension-placeholder": "^3.6.1",
    "@tiptap/extension-text-style": "^3.6.1",
    "@tiptap/pm": "^3.6.1",
    "@tiptap/react": "^3.6.1",
    "@tiptap/starter-kit": "^3.6.1"
  }
}
