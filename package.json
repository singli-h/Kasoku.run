{
  "name": "kasoku-monorepo",
  "private": true,
  "packageManager": "npm@10.5.2",
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "jest",
    "dev:web": "turbo run dev --filter=@kasoku/web",
    "build:web": "turbo run build --filter=@kasoku/web",
    "lint:web": "turbo run lint --filter=@kasoku/web",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "eslint-plugin-rulesdir": "^0.2.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.3.4",
    "turbo": "^2.5.4"
  }
}
